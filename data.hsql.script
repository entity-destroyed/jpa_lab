CREATE SEQUENCE PUBLIC.COMPANY_SEQ AS INTEGER START WITH 1 INCREMENT BY 50
CREATE SEQUENCE PUBLIC.EMPLOYEE_SEQ AS INTEGER START WITH 1 INCREMENT BY 50
CREATE MEMORY TABLE PUBLIC.COMPANY(ID BIGINT NOT NULL PRIMARY KEY,NAME VARCHAR(255))
CREATE MEMORY TABLE PUBLIC.EMPLOYEE(ID BIGINT NOT NULL PRIMARY KEY,JOB VARCHAR(255),NAME VARCHAR(255),SALARY INTEGER NOT NULL,WORK_START TIMESTAMP,COMPANY_ID BIGINT,CONSTRAINT FK5V50ED2BJH60N1GC7IFUXMGF4 FOREIGN KEY(COMPANY_ID) REFERENCES PUBLIC.COMPANY(ID))
